{
  "manifest_version": 3,
  "name": "Antigravity Visual Editor",
  "version": "1.0.0",
  "description": "Figma-like visual editor for live CSS editing in the browser.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "host_permissions": ["<all_urls>"]
}
